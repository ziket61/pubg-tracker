# PUBG API key from https://developer.pubg.com — never commit the real key.
PUBG_API_KEY=

# Set to "1" to use local fixtures (no real API calls).
# If PUBG_API_KEY is empty, mocks are forced on regardless of this value.
PUBG_USE_MOCKS=0

# Default platform shard for the home page featured leaderboard.
# Allowed: steam | psn | xbox | kakao | console | stadia
PUBG_DEFAULT_SHARD=steam

# Optional: GitHub token for scripts/sync-assets.ts to bypass the 60/h anonymous limit.
GITHUB_TOKEN=
